{%- style -%}
  .wholesale-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 560px;
    padding: 6rem 2rem;
    text-align: center;
    color: #fff;
    overflow: hidden;
  }
  .wholesale-hero__bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
  }
  .wholesale-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .wholesale-hero__overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(26, 31, 46, 0.92) 0%, rgba(36, 40, 51, 0.85) 50%, rgba(51, 79, 180, 0.80) 100%);
    z-index: 1;
  }
  .wholesale-hero__content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }
  .wholesale-hero__logo {
    display: inline-block;
    margin-bottom: 2rem;
  }
  .wholesale-hero__logo img {
    height: 36px;
    width: auto;
  }
  .wholesale-hero__subtitle {
    display: inline-block;
    font-size: 1.3rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    opacity: 0.8;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.5rem 1.5rem;
    border-radius: 2px;
  }
  .wholesale-hero__title {
    font-size: 3.8rem;
    line-height: 1.12;
    font-weight: 700;
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }
  .wholesale-hero__description {
    font-size: 1.7rem;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .wholesale-hero__cta {
    display: inline-block;
    background: #fff;
    color: #1a1f2e;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
    padding: 1.6rem 4rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .wholesale-hero__cta:hover {
    background: #334fb4;
    color: #fff;
  }
  .wholesale-hero__trust {
    margin-top: 3rem;
    font-size: 1.3rem;
    opacity: 0.6;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
  }
  @media screen and (max-width: 749px) {
    .wholesale-hero {
      min-height: 440px;
      padding: 4rem 1.5rem;
    }
    .wholesale-hero__title {
      font-size: 2.6rem;
    }
    .wholesale-hero__description {
      font-size: 1.5rem;
    }
    .wholesale-hero__logo img {
      height: 28px;
    }
  }
{%- endstyle -%}

<section class="wholesale-hero">
  <div class="wholesale-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      <img src="{{ 'hero-wholesale.jpg' | asset_url }}" alt="Wholesale textiles" loading="eager" width="1400" height="934">
    {%- endif -%}
  </div>
  <div class="wholesale-hero__overlay"></div>
  <div class="wholesale-hero__content{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="wholesale-hero__logo">
      <img src="{{ 'loopslink-logo.svg' | asset_url }}" alt="Loopslink Inc." width="200" height="40">
    </div>
    <div>
      <span class="wholesale-hero__subtitle">{{ section.settings.subtitle }}</span>
    </div>
    <h1 class="wholesale-hero__title">{{ section.settings.title }}</h1>
    <p class="wholesale-hero__description">{{ section.settings.description }}</p>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="wholesale-hero__cta">{{ section.settings.button_label }}</a>
    {%- endif -%}
    <p class="wholesale-hero__trust">Trusted by businesses nationwide since 1994</p>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "Wholesale Textile Distributor",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Your Trusted Wholesale Textile Partner for 30+ Years",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Loopslink Inc. is a leading wholesale distributor of quality textiles and apparel. From socks to hoodies, we supply businesses with bulk orders at competitive wholesale pricing.",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Request a Quote",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "default": "/pages/contact",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Wholesale Hero"
    }
  ]
}
{% endschema %}

