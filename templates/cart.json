{
  "sections": {
    "main": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Wholesale Inquiries Only",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Loopslink Inc. operates on a wholesale inquiry basis. We do not process orders through an online cart.</p><p>To place a bulk order, please contact our team directly and we will provide you with wholesale pricing and availability.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Request a Quote",
